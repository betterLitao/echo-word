{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoWord",
  "version": "0.1.0",
  "identifier": "com.echoword.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "title": "EchoWord",
        "url": "/splashscreen.html",
        "width": 400,
        "height": 300,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "main",
        "title": "EchoWord",
        "url": "/",
        "width": 1200,
        "height": 720,
        "center": true,
        "visible": false,
        "resizable": true,
        "decorations": false
      },
      {
        "label": "popup",
        "title": "EchoWord Popup",
        "url": "/popup.html",
        "width": 380,
        "height": 300,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "translation-icon",
        "title": "Translation Icon",
        "url": "/translation-icon.html",
        "width": 40,
        "height": 40,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
